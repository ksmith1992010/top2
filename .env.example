# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/top2

# Node environment (development | test | production)
NODE_ENV=development

# Better Auth (required in production; dev defaults apply locally/CI when unset)
BETTER_AUTH_SECRET=development-only-secret-at-least-32-characters
BETTER_AUTH_URL=http://localhost:3000

# Owner admin (kyle.smith@ottrestoration.com): set this to provision the real
# admin login on seed, in any environment. Must be an explicit, non-default value.
# Also overrides the demo dev-admin password locally/in preview.
# SEED_ADMIN_PASSWORD=your-explicit-password

# Production dev/demo-admin seed (admin@example.com) — operator-controlled opt-in.
# SEED_DEV_ADMIN=true
